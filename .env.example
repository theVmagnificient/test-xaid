# Copy to .env and fill in. .env is gitignored — real secrets never get committed or bundled.
# DataForSEO Basic Auth: base64 of "login:password". Used ONLY by tooling/agents for
# keyword research at content-generation time. Do NOT prefix with VITE_ (that would ship
# it to the browser) and do NOT reference it from any src/ file.
DATAFORSEO_AUTH_B64=
