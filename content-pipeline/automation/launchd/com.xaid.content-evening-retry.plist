<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>com.xaid.content-evening-retry</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>/Users/anastasia/Projects/xAID/xaid-landing/content-pipeline/automation/retry.sh</string>
  </array>
  <!-- 23:05 local: just after the Claude quota resets (~23:00). No-op unless
       the 18:00 run failed on the usage limit (dated retry marker present). -->
